<mujoco model="eyeball_bimanual">
  <!--
    Eyeball bimanual YAM scene.
    Two 7-DOF YAM arms + 2-DOF eye gimbal with camera.

    Coordinate convention (matches URDF / robot_gym):
      Z = up, X = forward (toward workspace), Y = left/right
      Left arm at y=+0.3048, Right arm at y=-0.3048 (12 inches from center)
      Eye at (0.0217, -0.0151, 0.369) relative to world origin

    Actuator ordering (16 total):
      [eye_pan, eye_tilt,
       left_joint1..6, left_gripper,
       right_joint1..6, right_gripper]
  -->

  <compiler angle="radian" meshdir="i2rt_yam/assets"/>

  <!--
    Physics settings:
      - implicitfast: stable with stiff PD actuators
      - Newton solver: best accuracy for contact-rich scenes
      - elliptic cone: more physical friction model
      - noslip_iterations: corrects velocity-level slip at contacts (essential for grasping)
  -->
  <option integrator="implicitfast" timestep="0.0005" solver="Newton" iterations="30" cone="elliptic" noslip_iterations="10"/>

  <statistic center="0.35 0 0.2" extent="2.0"/>

  <visual>
    <rgba haze="0.95 0.95 0.95 1"/>
    <global azimuth="120" elevation="-20"/>
    <headlight active="0"/>
    <quality shadowsize="8192"/>
  </visual>

  <!-- ==================== Defaults ==================== -->
  <default>
    <!-- YAM arm defaults (from i2rt_yam/yam.xml) -->
    <default class="yam">
      <position inheritrange="1"/>
      <joint frictionloss="0.1" axis="0 0 1"/>
      <default class="dm4340">
        <joint armature="0.032"/>
        <position kp="40" kv="2.5" forcerange="-28 28"/>
      </default>
      <default class="dm4310">
        <joint armature="0.0018"/>
        <position kp="10" kv="1" forcerange="-10 10"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" material="black"/>
      </default>
      <default class="collision">
        <geom group="3" type="capsule" solref="0.005 1"/>
        <default class="sphere_collision">
          <geom size="0.0006 0 0" type="sphere" rgba="1 0 0 1" condim="6"/>
        </default>
      </default>
      <default class="finger">
        <joint type="slide" armature="0.1" frictionloss="0.1"/>
        <position ctrlrange="-0.03 0.041" kp="1500" kv="30" inheritrange="0"/>
      </default>
    </default>

    <!-- Eye gimbal defaults (no collision, lightweight) -->
    <default class="eye">
      <joint damping="0.5" armature="0.01" frictionloss="0.001"/>
      <geom contype="0" conaffinity="0" density="0" group="2"/>
    </default>
  </default>

  <!-- ==================== Assets ==================== -->
  <asset>
    <!-- Materials -->
    <material name="black" rgba="0.12 0.12 0.12 1"/>
    <material name="white" rgba="0.9 0.9 0.9 1"/>
    <!-- LED indicator: fully self-illuminating bright green, matches real motor indicators -->
    <material name="led_green" rgba="0.0 1.0 0.1 1" emission="1.0" specular="0" shininess="0"/>
    <material name="table_mat" rgba="0.84 0.80 0.72 1" specular="0.02" shininess="0.02" reflectance="0" emission="0.08"/>
    <material name="eye_housing" rgba="0.15 0.15 0.15 1" specular="0.5"/>
    <material name="eye_lens" rgba="0.05 0.05 0.3 0.9" specular="0.9" shininess="1.0"/>

    <!-- Room surfaces -->
    <material name="room_white" rgba="0.85 0.80 0.73 1" specular="0.05" shininess="0.05" reflectance="0.02" emission="0.35"/>
    <material name="wall_dark" rgba="0.62 0.62 0.60 1" specular="0.03" shininess="0.03" reflectance="0.01" emission="0.18"/>

    <!-- Task object meshes are added programmatically via MjSpec (see tasks.py) -->

    <!-- Wrist camera mesh (OAK-1: ~36mm × 55mm × 28mm) -->
    <mesh name="oak_1" file="OAK-1.stl"/>

    <!-- Robot meshes (shared by both arms) -->
    <mesh file="model2.stl"/>
    <mesh file="model2__2.stl"/>
    <mesh file="model2__3.stl"/>
    <mesh file="model2__4.stl"/>
    <mesh file="model2__5.stl"/>
    <mesh file="model2__6.stl"/>
    <mesh file="model2__7.stl"/>
    <mesh file="model2__8.stl"/>
    <mesh file="model2__9.stl"/>
    <mesh file="model2__10.stl"/>
    <mesh file="model2__11.stl"/>
    <mesh file="model2__12.stl"/>
    <mesh file="model2__13.stl"/>
    <mesh file="model2__14.stl"/>
    <mesh file="model2__15.stl"/>
    <mesh file="model2__16.stl"/>
    <mesh file="model2__17.stl"/>
  </asset>

  <!-- ==================== World ==================== -->
  <worldbody>
    <!-- ============ Lighting ============ -->
    <!--
      Lab fluorescent: flat, even, low contrast.
      Positional ceiling light + directional fills.
      Heavy ambient to wash out contrast like real overhead panels.
    -->

    <!-- Ceiling light: directly behind robot, pointing forward+down toward workspace -->
    <light name="ceiling_main" pos="-0.3 0.0 1.1" dir="0.4 0 -1"
           diffuse="0.17 0.15 0.13" specular="0.03 0.03 0.03" ambient="0 0 0"
           cutoff="150" castshadow="false"/>

    <!-- Broad overhead fill -->
    <light name="overhead_fill" directional="true" dir="0 0 -1"
           diffuse="0.16 0.15 0.13" specular="0.02 0.02 0.02" ambient="0.22 0.20 0.17"
           castshadow="false"/>

    <!-- Back fill: lights the back wall -->
    <light name="back_fill" directional="true" dir="-0.3 0 -0.5"
           diffuse="0.11 0.10 0.09" specular="0.01 0.01 0.01" ambient="0.05 0.05 0.04"
           castshadow="false"/>

    <!-- Side fills -->
    <light name="left_fill" directional="true" dir="0 -0.3 -0.5"
           diffuse="0.08 0.08 0.08" specular="0.01 0.01 0.01" ambient="0.03 0.03 0.03"
           castshadow="false"/>

    <light name="right_fill" directional="true" dir="0 0.3 -0.5"
           diffuse="0.08 0.08 0.08" specular="0.01 0.01 0.01" ambient="0.03 0.03 0.03"
           castshadow="false"/>

    <!-- High ambient base -->
    <light name="ambient_base" directional="true" dir="0 0 -1"
           diffuse="0 0 0" specular="0 0 0" ambient="0.18 0.17 0.15"
           castshadow="false"/>

    <!-- White floor -->
    <geom name="floor" size="0 0 0.05" type="plane" material="room_white" pos="0 0 -0.76"/>

    <!-- Back wall (~1m in front of table center, behind workspace) -->
    <geom name="back_wall" type="box" size="0.005 1.5 1.0" pos="1.10 0 0.24"
          material="room_white" contype="0" conaffinity="0"/>

    <!-- Left wall (split into upper cream + lower dark grey to match real scene) -->
    <!-- Boundary at z=0.17, upper: z=0.17..1.24 (half=0.535), lower: z=-0.76..0.17 (half=0.465) -->
    <geom name="left_wall_upper" type="box" size="1.5 0.005 0.535" pos="0 1.25 0.705"
          material="room_white" contype="0" conaffinity="0"/>
    <geom name="left_wall_lower" type="box" size="1.5 0.005 0.465" pos="0 1.25 -0.295"
          material="wall_dark" contype="0" conaffinity="0"/>

    <!-- Right wall (mirrored from left wall) -->
    <geom name="right_wall" type="box" size="1.5 0.005 1.0" pos="0 -1.5 0.24"
          material="room_white" contype="0" conaffinity="0"/>

    <!-- Ceiling -->
    <geom name="ceiling" type="box" size="1.5 1.5 0.005" pos="0 0 1.24"
          material="room_white" contype="0" conaffinity="0"/>

    <!-- Workspace center marker (useful reference for objects) -->
    <site name="workspace_center" pos="0.43 0 0.05" size="0.005" rgba="1 1 0 0.3" group="4"/>

    <!-- ==================== Mounting Bar ==================== -->
    <!--
      Black aluminum extrusion bar that the arms are mounted on.
      6" (0.1524m) wide (X), same length as table 1.22m (Y).
      Top surface at z=0 (arm base height). 4cm tall.
    -->
    <geom name="mounting_bar" type="box" size="0.07 0.61 0.015" pos="0.019 0 -0.025"
          material="black" contype="0" conaffinity="0"/>

    <!-- ==================== Table ==================== -->
    <!--
      White table: 1.22m (Y) x 0.76m (X).
      Long side faces the robot arms.
      Near edge is 2" (0.0508m) in front of robot base (x=0).
      Top surface is 0.75" (0.01905m) below robot base (z=0).
      Table center: x=0.4308, z_top=-0.01905.
    -->
    <body name="table" pos="0.47 -0.01 -0.0">
      <geom name="table_top" type="box" size="0.38 0.61 0.0075" pos="0 0 -0.0344"
            material="table_mat" contype="1" conaffinity="1"
            friction="1.0 0.05 0.01" solref="0.002 1" solimp="0.99 0.999 0.001 0.5 2"/>
      <geom name="table_leg_fl" type="cylinder" size="0.025 0.355" pos="0.34 0.57 -0.385" material="table_mat"/>
      <geom name="table_leg_fr" type="cylinder" size="0.025 0.355" pos="0.34 -0.57 -0.385" material="table_mat"/>
      <geom name="table_leg_bl" type="cylinder" size="0.025 0.355" pos="-0.34 0.57 -0.385" material="table_mat"/>
      <geom name="table_leg_br" type="cylinder" size="0.025 0.355" pos="-0.34 -0.57 -0.385" material="table_mat"/>
    </body>

    <!-- ==================== Eye / Camera Gimbal ==================== -->
    <!--
      2-DOF pan/tilt gimbal. No collision bodies.
      Pan  (yaw):   rotates around Z axis
      Tilt (pitch): rotates around X axis (after pan)
      Camera looks along +X in world when both joints = 0.
    -->
    <body name="eye_base" pos="0.0217 -0.0151 0.369" childclass="eye">
      <!-- 6 cube-map pinhole cameras for 360° equirectangular rendering.
           Fixed at the eye position — no gimbal.
           Each face has fovy=100° (>90° gives overlap for smooth blending at seams).
           Camera looks along -Z_cam; xyaxes define camera X,Y axes in world frame. -->
      <camera name="cube_px" pos="0 0 0" fovy="100" xyaxes="0 -1 0  0 0 1"/>  <!-- +X (front)  -->
      <camera name="cube_nx" pos="0 0 0" fovy="100" xyaxes="0 1 0  0 0 1"/>   <!-- -X (back)   -->
      <camera name="cube_py" pos="0 0 0" fovy="100" xyaxes="1 0 0  0 0 1"/>   <!-- +Y (left)   -->
      <camera name="cube_ny" pos="0 0 0" fovy="100" xyaxes="-1 0 0  0 0 1"/>  <!-- -Y (right)  -->
      <camera name="cube_pz" pos="0 0 0" fovy="100" xyaxes="0 -1 0  -1 0 0"/> <!-- +Z (up)     -->
      <camera name="cube_nz" pos="0 0 0" fovy="100" xyaxes="0 -1 0  1 0 0"/>  <!-- -Z (down)   -->

      <!-- Static exo camera: same intrinsics as eye_camera, fixed 45° downward look (no gimbal). -->
      <camera name="exo_camera" pos="0 0 0" fovy="100"
              xyaxes="0 -1 0  0.707107 0 0.707107"/>

      <!-- Pan body (yaw around Z) -->
      <body name="eye_pan" pos="0 0 0">
        <inertial pos="0 0 0" mass="0.05" diaginertia="1e-5 1e-5 1e-5"/>
        <joint name="eye_pan" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>

        <!-- Tilt body (pitch around X) -->
        <body name="eye_tilt">
          <inertial pos="0 0 0" mass="0.03" diaginertia="5e-6 5e-6 5e-6"/>
          <joint name="eye_tilt" type="hinge" axis="0 1 0" range="-1.5708 1.5708"/>

          <!-- Camera sensor: looks along +X in neutral (xyaxes rotates -Z to +X). -->
          <camera name="eye_camera" pos="0 0 0" fovy="100"
                  xyaxes="0 -1 0 0 0 1"/>

          <site name="eye_gaze_site" pos="0 0 0" size="0.003" rgba="0 1 0 0.5" group="4"/>
        </body>
      </body>
    </body>

    <!-- ==================== Left Arm (y=+0.3) ==================== -->
